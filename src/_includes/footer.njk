<footer class="bg-htbw-green text-white py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- About Column -->
      <div>
        <h2 class="font-heading text-2xl text-white mb-4">{{ config.siteName }}</h2>
        <p class="text-white/80 leading-relaxed mb-4">
          {{ config.footerMessage | safe }}
        </p>
        <p class="text-white/70 text-sm">
          {{ config.organization }}
        </p>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-body text-xl text-white mb-4">Kontakt</h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:{{ config.email }}" class="text-white/80 hover:text-htbw-pink transition-colors flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {{ config.email }}
            </a>
          </li>
          {% if config.pressepoolUrl %}
          <li>
            <a 
              href="{{ config.pressepoolUrl }}" 
              download
              class="text-white/80 hover:text-htbw-pink transition-colors flex items-center gap-2"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Pressepool herunterladen
              <span class="text-white/50 text-xs">(ZIP)</span>
            </a>
          </li>
          {% endif %}
          <li class="flex items-center gap-4 pt-2">
            <a href="{{ config.socialMedia.instagram }}" target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-htbw-pink transition-colors" aria-label="Instagram (öffnet in neuem Tab)">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a href="{{ config.socialMedia.facebook }}" target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-htbw-pink transition-colors" aria-label="Facebook (öffnet in neuem Tab)">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="{{ config.socialMedia.youtube }}" target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-htbw-pink transition-colors" aria-label="YouTube (öffnet in neuem Tab)">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal Column -->
      <div>
        <h3 class="font-body text-xl text-white mb-4">Rechtliches</h3>
        <ul class="space-y-2">
          {% for link in config.footerLinks %}
            <li>
              <a href="{{ link.url | url }}" class="text-white/80 hover:text-htbw-pink transition-colors">
                {{ link.name }}
              </a>
            </li>
          {% endfor %}
        </ul>

        <!-- Cookie/Video Consent Toggle -->
        <div class="mt-6 pt-4 border-t border-white/20">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-white/80 text-sm">YouTube Videos</p>
              <p id="consent-status-label" class="text-white/70 text-xs mt-0.5">Status wird geladen...</p>
            </div>
            <button
              type="button"
              id="consent-toggle"
              role="switch"
              aria-checked="false"
              aria-label="YouTube Video Einbettung aktivieren oder deaktivieren"
              class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-htbw-pink focus:ring-offset-2 focus:ring-offset-htbw-green bg-white/20"
            >
              <span
                aria-hidden="true"
                class="consent-toggle-thumb pointer-events-none inline-block h-5 w-5 rounded-full bg-white shadow transform transition-transform duration-200 translate-x-0"
              ></span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/20 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/70 text-sm">
        &copy; {{ config.year }} {{ config.organization }}. Alle Rechte vorbehalten.
      </p>
      <p class="font-heading text-2xl text-htbw-pink-light font-bold flex items-center gap-2">
        Stay Wild!
        <img
          src="{{ '/assets/images/logo/pride-flag.svg' | url }}"
          alt="Pride Flag"
          class="h-7 w-auto"
        >
      </p>
    </div>
  </div>
</footer>
