---
layout: base.njk
---

<article>

  {# Post Header #}
  <header class="relative -z-0">
    <div class="max-w-3xl py-1 mx-auto">

      {# Polaroid/Sticker Card #}
      <div class="sticker-card pb-8 md:pb-12 mx-auto">
        {# Image #}
        <div class="w-full overflow-hidden mb-4">
          {% if image %}
            <img 
              src="{{ image }}" 
              alt="{{ imageAlt or title }}"
              class="w-full h-auto object-cover"
            >
          {% else %}
            <div class="w-full aspect-video bg-htbw-green/10 flex items-center justify-center">
              <img
                src="{{ '/assets/images/logo/htbw-logo-main.avif' | url }}"
                alt=""
                aria-hidden="true"
                class="h-16 w-auto opacity-30"
              >
            </div>
          {% endif %}
        </div>

        {# Caption area like a Polaroid label #}
        <div class="px-2 pb-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-block px-2 py-1 text-xs font-medium bg-htbw-green/10 text-htbw-green rounded">
              {{ category or 'News' }}
            </span>
            <time class="text-sm text-htbw-black/60" datetime="{{ date }}">
              {{ date | dateFormat }}
            </time>
          </div>
          <h1 class="font-heading text-2xl md:text-3xl text-htbw-green">{{ title }}</h1>
        </div>
      </div>

    </div>
  </header>

  {# Post Content #}
  <div class="section">
    <div class="max-w-3xl mx-auto prose prose-lg prose-green
      prose-headings:font-heading prose-headings:text-htbw-green
      prose-p:text-htbw-black prose-p:leading-relaxed
      prose-a:text-htbw-pink prose-a:no-underline hover:prose-a:text-htbw-pink-dark
      prose-strong:text-htbw-black">
      {{ content | safe }}
    </div>
  </div>

  {# Back to Blog #}
  <div class="section pt-0">
    <div class="max-w-3xl mx-auto">
      <a href="{{ '/blog/' | url }}" class="inline-flex items-center gap-2 text-htbw-green hover:text-htbw-pink transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentcolor" viewbox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19l-7-7 7-7"/>
        </svg>
        Zurück zum Blog
      </a>
    </div>
  </div>
</article>