---
layout: base.njk
---

<article>
  {# Post Header with integrated image #}
  <header class="relative -z-0">

    {# Featured Image or fallback bg #}
    <div class="w-full h-64 md:h-96 overflow-hidden">
      {% if image %}
        <img 
        src="{{ image }}" 
        alt="{{ imageAlt or title }}"
        class="w-full h-full object-cover"
      >
      {% else %}
        <div class="w-full h-full bg-htbw-green"></div>
      {% endif %}
    </div>

    {# Gradient overlay with title #}
    <div class="absolute inset-0 bg-gradient-to-t from-htbw-green via-htbw-green/60 to-transparent flex items-end">
      <div class="max-w-3xl mx-auto w-full pb-8 md:pb-12">
        <div class="flex items-center gap-3 mb-3">
          <span class="inline-block px-3 py-1 text-sm font-medium bg-white/20 text-white rounded">
            {{ category or 'News' }}
          </span>
          <time class="text-white/80 text-sm" datetime="{{ date }}">
            {{ date | dateFormat }}
          </time>
        </div>
        <h1 class="font-heading text-3xl md:text-5xl text-white text-balance">{{ title }}</h1>
      </div>
    </div>

  </header>

  {# Featured Image
  {% if image %}
    <div class="max-w-4xl mx-auto px-4 -mt-8 relative z-10">
      <div class="aspect-video overflow-hidden rounded-lg shadow-lg">
        <img 
        src="{{ image }}" 
        alt="{{ imagealt or title }}"
        class="w-full h-full object-cover"
      >
      </div>
    </div>
  {% endif %} #}

  {# Post Content #}
  <div class="section">
    <div class="max-w-3xl mx-auto prose prose-lg prose-green
      prose-headings:font-heading prose-headings:text-htbw-green
      prose-p:text-htbw-black prose-p:leading-relaxed
      prose-a:text-htbw-pink prose-a:no-underline hover:prose-a:text-htbw-pink-dark
      prose-strong:text-htbw-black">
      {{ content | safe }}
    </div>
  </div>

  {# Back to Blog #}
  <div class="section pt-0">
    <div class="max-w-3xl mx-auto">
      <a href="{{ '/blog/' | url }}" class="inline-flex items-center gap-2 text-htbw-green hover:text-htbw-pink transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentcolor" viewbox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19l-7-7 7-7"/>
        </svg>
        Zurück zum Blog
      </a>
    </div>
  </div>
</article>