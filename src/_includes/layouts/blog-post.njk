---
layout: base.njk
---

<article>
  {# Post Header #}
  <header class="section bg-htbw-green text-white pb-12">
    <div class="max-w-3xl mx-auto text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 text-sm font-medium bg-white/20 rounded">
          {{ category or 'News' }}
        </span>
        <time class="text-white/80" datetime="{{ date }}">
          {{ date | dateFormat }}
        </time>
      </div>
      <h1 class="font-heading text-3xl md:text-5xl text-white text-balance">{{ title }}</h1>
    </div>
  </header>

  {# Featured Image #}
  {% if image %}
  <div class="max-w-4xl mx-auto px-4 -mt-8 relative z-10">
    <div class="aspect-video overflow-hidden rounded-lg shadow-lg">
      <img 
        src="{{ image }}" 
        alt="{{ imageAlt or title }}"
        class="w-full h-full object-cover"
      >
    </div>
  </div>
  {% endif %}

  {# Post Content #}
  <div class="section">
    <div class="max-w-3xl mx-auto prose prose-lg prose-htbw">
      {{ content | safe }}
    </div>
  </div>

  {# Back to Blog #}
  <div class="section pt-0">
    <div class="max-w-3xl mx-auto">
      <a href="/blog/" class="inline-flex items-center gap-2 text-htbw-green hover:text-htbw-pink transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Zurück zum Blog
      </a>
    </div>
  </div>
</article>
