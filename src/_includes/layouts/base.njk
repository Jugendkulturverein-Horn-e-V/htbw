<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or config.siteName }} | {{ config.siteName }}</title>
  <meta name="description" content="{{ description or config.siteDescription }}">
  
  <!-- Open Graph -->
  <meta property="og:title" content="{{ title or config.siteName }}">
  <meta property="og:description" content="{{ description or config.siteDescription }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="de_DE">
  <meta content="{{ '/assets/images/banner/Banner-2026.avif' | url }}" property="og:image">

  <meta content="JRjDBYSXQ4XQaBrq0jsnNEGyturZP65lERJ_W21XBx4" name="google-site-verification">
  
  <!-- Favicon placeholder -->
  <link rel="shortcut icon" href="{{ '/assets/images/logo/htbw-icon-small.png' | url }}" type="image/x-icon">
  <link rel="apple-touch-icon" href="{{ '/assets/images/logo/htbw-icon-large.png' | url }}">
  
  <!-- Preload fonts -->
  <link rel="preload" href="{{ '/assets/fonts/FrenteH1-Regular.woff2' | url }}" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="{{ '/assets/fonts/Inter_18pt-Regular.woff2' | url }}" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="{{ '/assets/fonts/Inter_18pt-Medium.woff2' | url }}" as="font" type="font/woff2" crossorigin>
  
  <!-- Stylesheet -->
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">

  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-Iczx42Kn4ol7tnGLvBzhx.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "11te und letzte Horn to be Wild Festival",
    "description": "11 Jahre. Unzählige Erinnerungen. Ein letztes Mal.
  Nach 11 unvergesslichen Jahren heißt es: Wir feiern diesen Sommer unser letztes Horn to be Wild.

  Unser Musikfestival lässt den Stadtteil Bremen Horn jedes Jahr für ein paar Stunden laut werden! Seit 2015 organisieren wir es ehrenamtlich mit viel Herzblut, um jungen Künstlern und Künstlerinnen eine Bühne zu bieten und einen einzigartigen Tag in Horn zu schaffen. Gäste können nach Belieben vor der Bühne tanzen oder auf Picknickdecken entspannen, das Angebot an den Foodtrucks genießen oder an den Mitmachständen Verschiedenes erleben.",
    "image": "https://htbw.de/assets/images/banner/Banner-2026.avif",
    "startDate": "2026-09-05T15:00",
    "endDate": "2026-09-05T23:00",
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "location": {		
      "@type": "Place",
      "name": "Rhododendronpark Bremen",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Deliusweg 40",
        "addressLocality": "Bremen",
        "postalCode": "28359",
        "addressCountry": "DE"
      }
    },
    "offers": [{
      "@type": "Offer",
      "name": "Early Bird Ticket",
      "price": "10",
      "priceCurrency": "EUR",
      "validFrom": "2026-01-01",
      "url": "https://www.lokale-momente.de/bremen/events/horn-to-be-wild-festival-2026-ein-letztes-mal-bbcf1",
      "availability": "https://schema.org/SoldOut"
    },{
      "@type": "Offer",
      "name": "Einzelticket - Preisstufe 1",
      "price": "15",
      "priceCurrency": "EUR",
      "validFrom": "2026-02-01",
      "url": "https://www.lokale-momente.de/bremen/events/horn-to-be-wild-festival-2026-ein-letztes-mal-bbcf1",
      "availability": "https://schema.org/InStock"
    },{
      "@type": "Offer",
      "name": "Fünf Freunde - Preisstufe 1",
      "price": "60",
      "priceCurrency": "EUR",
      "validFrom": "2026-02-01",
      "url": "https://www.lokale-momente.de/bremen/events/horn-to-be-wild-festival-2026-ein-letztes-mal-bbcf1",
      "availability": "https://schema.org/InStock"
    },{
      "@type": "Offer",
      "name": "Barrierefreiheitsticket - Preisstufe 1",
      "price": "15",
      "priceCurrency": "EUR",
      "validFrom": "2026-02-01",
      "url": "https://www.lokale-momente.de/bremen/events/horn-to-be-wild-festival-2026-ein-letztes-mal-bbcf1",
      "availability": "https://schema.org/InStock"
    }]
  }
  </script>

</head>
<body class="min-h-screen flex flex-col">
  {% include "header.njk" %}
  
  <main id="main-content" class="flex-grow">
    {{ content | safe }}
    {% include "cta-final.njk" %}
  </main>

  {% include "footer.njk" %}
  {% include "cookie-banner.njk" %}
  {% include "video-modal.njk" %}
  
  <!-- JavaScript -->
  <script src="{{ '/js/main.js' | url }}" defer></script>
  <script>
  window.SITE_CONFIG = {{ config | dump | safe }};
</script>
</body>
</html>
