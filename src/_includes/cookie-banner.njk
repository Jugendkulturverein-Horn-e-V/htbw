<!-- Cookie Consent Banner (GDPR-compliant) -->
<div id="cookie-banner" class="cookie-banner no-print" role="dialog" aria-labelledby="cookie-title" aria-describedby="cookie-description">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="flex flex-col md:flex-row items-start md:items-center gap-4">
      <div class="flex-grow">
        <h2 id="cookie-title" class="font-heading text-lg mb-1">Cookies & Videos</h2>
        <p id="cookie-description" class="text-white/80 text-sm leading-relaxed">
          Wir nutzen YouTube, um euch Videos zu zeigen. Beim Abspielen wird eine Verbindung zu Googles Servern hergestellt und deine IP-Adresse übertragen. Mehr dazu in der <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="text-white underline hover:text-htbw-pink">Datenschutzerklärung von Google</a> und unserer <a href="{{ '/datenschutz' | url }}" target="_blank" rel="noopener noreferrer" class="text-white underline hover:text-htbw-pink">Datenschutzerklärung</a>. 
          Wir nutzen die datenschutzfreundliche Einbettungsvariante von YouTube, die keine Tracking-Cookies setzt.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <button 
          type="button"
          id="cookie-accept"
          class="btn bg-white text-htbw-green hover:bg-htbw-cream text-sm"
        >
          Videos aktivieren
        </button>
        <button 
          type="button"
          id="cookie-decline"
          class="btn border border-white/50 text-white hover:bg-white/10 text-sm"
        >
          Ablehnen
        </button>
      </div>
    </div>
  </div>
</div>
