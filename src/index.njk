{# Blog Teaser Section #}
<section id="blog" class="section bg-htbw-green/5">
  <div class="max-w-7xl mx-auto">
    <h2 class="section-title" data-animate>Wie passen 🦄, ♻ und 🎉zusammen?</h2>
    <p class="text-center text-lg md:text-xl text-htbw-black mb-8 max-w-2xl mx-auto" data-animate>
      In unseren Blog-Post gibt es nicht nur Informationen zum Festival, sondern auch noch viele Einblicke in die Organisation.
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {% for post in collections.posts | limit(3) %}
      <article class="sticker-card" data-animate>
        {% if post.data.image %}
        <div class="aspect-video overflow-hidden rounded-lg mb-4">
          {% image post.data.image, post.data.imageAlt or post.data.title, "(min-width: 768px) 33vw, 100vw", "w-full h-full object-cover" %}
        </div>
        {% else %}
        <div class="aspect-video overflow-hidden rounded-lg mb-4 bg-htbw-green/10 flex items-center justify-center">
          <img
            src="{{ '/assets/images/logo/htbw-logo-main.avif' | url }}"
            alt=""
            aria-hidden="true"
            class="h-16 w-auto opacity-30"
          >
        </div>
        {% endif %}
        
        <div class="flex items-center gap-3 mb-3">
          <span class="inline-block px-2 py-1 text-xs font-medium bg-htbw-green/10 text-htbw-green rounded">
            {{ post.data.category or 'News' }}
          </span>
          <time class="text-sm text-htbw-black/60" datetime="{{ post.data.date }}">
            {{ post.data.date | dateFormat }}
          </time>
        </div>
        
        <h2 class="font-body text-xl md:text-2xl text-htbw-green mb-3">
          <a href="{{ post.url }}" class="hover:text-htbw-pink transition-colors">
            {{ post.data.title }}
          </a>
        </h2>
        
        <p class="text-htbw-black leading-relaxed mb-4">
          {{ post.data.teaser }}
        </p>
        
        <a href="{{ post.url }}" aria-label="Blogbeitrag zu {{ post.data.title }} lesen" class="text-htbw-pink font-medium hover:text-htbw-pink-dark transition-colors inline-flex items-center gap-1">
          Weiterlesen
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </article>
      {% else %}
      <article class="sticker-card" data-animate>
        <span class="inline-block px-2 py-1 text-xs font-medium bg-htbw-green/10 text-htbw-green rounded mb-3">
          News
        </span>
        <h3 class="font-body text-xl text-htbw-green mb-2">Bald mehr Neuigkeiten</h3>
        <p class="text-htbw-black text-sm leading-relaxed">Hier werden bald Neuigkeiten zum Festival erscheinen.</p>
      </article>
      {% endfor %}
    </div>

    {% if collections.posts.length > 3 %}
    <div class="text-center mt-8">
      <a href="{{ '/blog/' | url }}" aria-label="Alle Blog-Posts ansehen" class="btn btn-outline">
        Alle weiteren Blog-Posts findest du hier
      </a>
    </div>
    {% endif %}
  </div>
</section>

{# Sponsors Section #}
<section id="sponsors" class="section relative overflow-hidden">
  {# Watercolor decorations #}
  <div class="watercolor-blob -top-20 -right-10 w-64 h-64 animate-float-slow" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-1-pink-s.avif' | url }}" alt="" class="w-full h-full object-contain">
  </div>
  <div class="watercolor-blob -bottom-10 -left-10 w-48 h-48 animate-float-slow" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-5-grün-s.avif' | url }}" alt="" class="w-full h-full object-contain">
  </div>

  <div class="max-w-7xl mx-auto">
    <h2 class="section-title" data-animate>Unsere Unterstützer</h2>
    <p class="text-center text-lg md:text-xl text-htbw-black mb-12 max-w-2xl mx-auto" data-animate>
      ... ohne die das Festival nicht möglich wäre!<br />Einen großen Dank an Euch 💚
    </p>

    {# Sticker-collection style layout #}
    <div class="relative py-8">
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
        {% for sponsor in sponsors.sponsors %}
        <div class="sticker-card p-4 md:p-6" data-animate>
          {% if sponsor.url %}
          <a 
            href="{{ sponsor.url }}" 
            target="_blank" 
            rel="noopener noreferrer"
            class="block"
            aria-label="{{ sponsor.name }} Website besuchen (öffnet in neuem Tab)"
          >
            {% image sponsor.logo, sponsor.alt, "200px", "h-12 md:h-16 w-auto transition-all duration-300" %}
          </a>
          {% else %}
          <img 
            src="{{ sponsor.logo }}" 
            alt="{{ sponsor.alt }}"
            loading="lazy"
            class="h-12 md:h-16 w-auto grayscale hover:grayscale-0 transition-all duration-300"
          >
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
