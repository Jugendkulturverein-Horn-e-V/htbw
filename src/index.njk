---
layout: base.njk
title: Ein letztes Mal
description: Horn to be Wild 2026 - Die 11. und letzte Ausgabe des Bremer Musikfestivals im Rhododendronpark. Sei dabei beim großen Finale!
---

{# Post-Festival Thank You Banner #}
<section id="thankYou" data-post-festival class="thank-you-banner hidden">
  <div class="max-w-4xl mx-auto px-4">
    <h1 class="font-heading text-4xl md:text-6xl mb-6">Danke!</h1>
    <p class="text-xl md:text-2xl text-white/90 leading-relaxed text-pretty">
      {{ config.thankYouMessage | safe }}
    </p>
    <br />
    <p class="font-heading text-4xl md:text-6xl mb-6 font-bold">Stay Wild!</p>
  </div>
</section>

{# Hero Section #}
<section id="hero" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden" data-pre-festival>
  {# Watercolor decorations #}
  <div class="watercolor-blob -top-20 -left-20 w-64 h-64 animate-float" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-1-pink-s.avif' | url }}" alt="" class="w-full h-full object-contain">
  </div>
  <div class="watercolor-blob -bottom-10 -right-10 w-48 h-48 animate-float-slow" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-5-grün-s.avif' | url }}" alt="" class="w-full h-full object-contain">
  </div>

  {# Static decorative blob after hero section #}
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none -z-10 opacity-30" aria-hidden="true">
    {% image "./src/assets/images/watercolor/klecks-4-grün.avif", "", "(min-width: 1024px) 600px, 100vw", "w-[600px] h-[600px] rotate-[-30deg] object-contain max-w-3xl", true %}
  </div>

  <div class="relative z-10 text-center px-4 py-16 md:py-24">
    {# {# Logo #}
    {# <div class="mb-8" data-animate>
      <img 
        src="/assets/images/logo/htbw-logo-main.avif" 
        alt="Horn to be Wild Festival Logo" 
        class="w-48 md:w-64 h-auto mx-auto"
      >
    </div> #}

    {# Main Headline #}
    <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-htbw-green mb-4 text-balance" data-animate>
      {{ config.heroHeadline }}
    </h1>

    <p class="text-xl md:text-2xl text-htbw-black mb-4" data-animate>
      {{ config.heroSubline }}
    </p>

    <p class="text-lg text-htbw-black mb-8" data-animate>
      {{ config.festivalDate | dateFormat }} | {{ config.location }}
    </p>

    {# Countdown Timer #}
    <div id="countdown" class="countdown mb-12" data-animate aria-live="polite" aria-label="Countdown zum Festival">
      {# JS will populate this #}
    </div>

    {# CTA Button #}
    <div data-animate>
      <a 
        href="{{ config.ticketUrl }}" 
        target="_blank" 
        rel="noopener noreferrer"
        class="btn btn-primary text-lg px-8 py-4"
        aria-label="Ticket-Shop öffnen (öffnet in neuem Tab)"
      >
        Jetzt dein Ticket sichern!
      </a>
      <p class="text-sm text-htbw-black mt-3">
        Powered by <strong><a href="{{ config.ticketUrl }}" target="_blank" 
        rel="noopener noreferrer" aria-label="{{ config.ticketPartner }} Website öffnen (öffnet in neuem Tab)" class="underline hover:text-htbw-pink transition-colors">{{ config.ticketPartner }}</a></strong>
      </p>
    </div>
  </div>
</section>

{# Final Year Message Section #}
<section id="finalYear" class="section bg-htbw-green text-white" data-animate>
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="font-heading text-3xl md:text-4xl text-white mb-6 text-balance">
      11 Jahre. Unzählige Erinnerungen. Ein letztes Mal.
    </h2>
    <p class="text-lg md:text-xl text-white/90 leading-relaxed text-pretty">
      {{ config.aboutTeaser | safe }}
    </p>
  </div>
</section>

{# Key Info Bar #}
<section id="tldr" class="py-8 bg-htbw-cream border-y border-htbw-brown/10">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-8 text-center">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-htbw-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="font-medium text-htbw-black">{{ config.festivalDate | dateFormat }}</span>
      </div>
      <span class="hidden md:block text-htbw-black/30">|</span>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-htbw-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span class="font-medium text-htbw-black">{{ config.location }}</span>
      </div>
      <span class="hidden md:block text-htbw-black/30">|</span>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-htbw-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
        </svg>
        <span class="font-medium text-htbw-black">{{ config.edition }}. Ausgabe</span>
      </div>
    </div>
  </div>
</section>

{# Lineup Section #}
<section id="acts" class="section flex relative overflow-hidden">
    {# Watercolor decorations #}
    <div class="watercolor-blob -top-20 -right-10 w-64 h-64 animate-float-slow" aria-hidden="true">
      <img src="{{ '/assets/images/watercolor/small/klecks-3-pink-s.avif' | url }}" alt="" class="w-full h-full object-contain">
    </div>
    <div class="watercolor-blob -bottom-10 -left-10 w-48 h-48 animate-float-slow" aria-hidden="true">
      <img src="{{ '/assets/images/watercolor/small/klecks-7-grün-s.avif' | url }}" alt="" class="w-full h-full object-contain">
    </div>

  <div class="max-w-7xl mx-auto">
    <h2 class="section-title" data-animate>Unser Line-Up {{ config.year }} 🎙️</h2>
    
    {# Stage Filter (if multiple stages) #}
    {% if lineup.stages.length > 1 %}
    <div class="flex flex-wrap justify-center gap-2 mb-12" role="tablist" aria-label="Bühnenfilter">
      <button 
        class="year-tab active" 
        role="tab"
        aria-selected="true"
        data-stage="all"
      >
        Alle
      </button>
      {% for stage in lineup.stages %}
      <button 
        class="year-tab" 
        role="tab"
        aria-selected="false"
        data-stage="{{ stage.id }}"
      >
        {{ stage.name }}
      </button>
      {% endfor %}
    </div>
    {% endif %}

    {# Acts Grid #}
    {% set visibleActs = lineup.acts | selectattr("visible") | list %}
    <div class="grid gap-6 md:gap-8 {{ 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' if visibleActs | length > 0 else 'grid-cols-1 max-w-96 mx-auto' }}">
      {% for act in lineup.acts %}
        {% if act.visible %}
        <article class="sticker-card" data-animate data-stage-card="{{ act.stage | slug }}">
          {# Artist Image #}
          <div class="aspect-square relative overflow-hidden rounded-lg mb-4">
            {% image act.image, act.alt, "(min-width: 1280px) 33vw, (min-width: 640px) 50vw, 100vw", "w-full h-full object-cover" %}
            {% if act.youtubeEmbedId %}
            <button 
              type="button"
              class="absolute inset-0 flex items-center justify-center bg-black/40 hover:bg-black/50 transition-colors"
              data-video-trigger
              data-video-id="{{ act.youtubeEmbedId }}"
              aria-label="Video von {{ act.name }} abspielen"
            >
              <svg class="w-16 h-16 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
            {% endif %}
          </div>

          {# Artist Info #}
          <div>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-htbw-pink/10 text-htbw-pink rounded mb-2">
              {{ act.genre }}
            </span>
            <h3 class="font-body font-bold text-2xl text-htbw-green mb-1">{{ act.name }}</h3>
            <p class="text-sm text-htbw-black mb-3">
              {{ act.time }} Uhr | {{ act.stage }}
            </p>
            <p class="text-htbw-black text-sm leading-relaxed mb-4">
              {{ act.description }}
            </p>

            {# Links #}
            <div class="flex gap-3">
              {% if act.spotifyUrl %}
              <a 
                href="{{ act.spotifyUrl }}" 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-htbw-green hover:text-htbw-pink transition-colors"
                aria-label="{{ act.name }} auf Spotify (öffnet in neuem Tab)"
              >
                <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                </svg>
              </a>
              {% endif %}
              {% if act.youtubeEmbedId %}
              <a 
                href="https://www.youtube.com/watch?v={{ act.youtubeEmbedId }}"
                target="_blank" 
                rel="noopener noreferrer"
                class="text-htbw-green hover:text-htbw-pink transition-colors"
                aria-label="{{ act.name }} auf YouTube (öffnet in neuem Tab)"
              >
                <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
              {% endif %}
            </div>
          </div>
        </article>
        {% endif %}
      {% else %}
      <article class="sticker-card" data-animate>
          {# Backup Image #}
          <div class="aspect-square relative overflow-hidden rounded-lg mb-4">
            <img 
              src="{{ '/assets/images/bands/placeholder.avif' | url }}" 
              alt=""
              loading="lazy"
              class="w-full h-full object-cover"
            >
          </div>

          {# Backup Info #}
          <div>
            <h3 class="font-body font-bold text-2xl text-htbw-green mb-1">Kommt noch ...</h3>
            <p class="text-htbw-black text-sm leading-relaxed mb-4">
              Hier werden wir dir in Kürze Schritt für Schritt unsere Acts fürs dieses Jahr vorstellen.
            </p>
          </div>
        </article>
      {% endfor %}
    </div>

    {# Ticket CTA #}
    <div class="text-center mt-12" data-animate>
      <a 
        href="{{ config.ticketUrl }}" 
        target="_blank" 
        rel="noopener noreferrer"
        class="btn btn-primary text-lg px-8 py-4"
        aria-label="Ticket-Shop öffnen (öffnet in neuem Tab)"
      >
        Jetzt dein Ticket sichern!
      </a>
    </div>
  </div>
</section>

{# Festival Gallery Section - Creative Masonry Layout #}
<section id="gallery" class="section bg-htbw-green/5 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <h2 class="section-title" data-animate>Festivalatmosphäre 📸</h2>
    <p class="text-center text-lg md:text-xl text-htbw-black mb-12 max-w-2xl mx-auto" data-animate>
      Musik, Freundschaft und unvergessliche Momente im Herzen des Rhododendronparks.
    </p>
    
    {# Creative Bento Grid Layout #}
    <div class="grid grid-cols-4 md:grid-cols-6 lg:grid-cols-12 gap-3 md:gap-4 auto-rows-[80px] md:auto-rows-[100px]">
      
      {# Large featured image - top left #}
      <div class="col-span-4 md:col-span-4 lg:col-span-5 row-span-3 md:row-span-4 relative group overflow-hidden rounded-2xl bg-htbw-brown/10" data-animate>
        {% image "./src/assets/images/gallery/HTBW22_146.avif", "Festivalbesucher bei Sonnenuntergang vor der Hauptbühne", "(min-width: 1280px) 500px, (min-width: 768px) 50vw, 100vw", "w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" %}
        <div class="absolute inset-0 bg-gradient-to-t from-htbw-green/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <span class="absolute bottom-4 left-4 text-white font-heading font-bold text-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300">Hauptbühne 2024</span>
      </div>
      
      {# Vertical tall image #}
      <div class="col-span-2 md:col-span-2 lg:col-span-3 row-span-2 md:row-span-3 relative group overflow-hidden rounded-2xl sticker-card p-0 bg-htbw-brown/10" data-animate>
        {% image "./src/assets/images/gallery/HTBW22_17.avif", "Bunte Lichtinstallation im Waldgebiet", "(min-width: 1280px) 300px, 25vw", "w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" %}
      </div>
      
      {# Square image with overlay text #}
      <div class="col-span-2 md:col-span-2 lg:col-span-4 row-span-2 lg:row-span-4 relative group overflow-hidden rounded-2xl bg-htbw-brown/10" data-animate>
        {% image "./src/assets/images/gallery/crowd.webp", "Publikum bei einem Konzert", "(min-width: 1280px) 400px, 25vw", "w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" %}
        {# <div class="absolute inset-0 bg-htbw-pink/20 mix-blend-multiply">2023</div> #}
      </div>
      
      {# Small accent boxes with text #}
      {# <div class="col-span-2 lg:col-span-2 row-span-2 bg-htbw-pink rounded-2xl flex items-center justify-center p-4" data-animate>
        <p class="font-heading text-white text-center text-lg md:text-xl">11 Jahre Musik</p>
      </div>
      
      <div class="col-span-2 lg:col-span-2 row-span-2 bg-htbw-green rounded-2xl flex items-center justify-center p-4" data-animate>
        <p class="font-heading text-white text-center text-lg md:text-xl">1 Familie</p>
      </div> #}
      
      {# Wide panorama image #}
      <div class="col-span-4 md:col-span-4 lg:col-span-7 row-span-2 relative group overflow-hidden rounded-2xl bg-htbw-brown/10" data-animate>
         {% image "./src/assets/images/gallery/Antiheld-BG.webp", "Band Antiheld auf der Bühne stehend, Blick Richtung Publikum, Konfetti Regen", "(min-width: 1280px) 700px, (min-width: 768px) 66vw, 100vw", "w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" %}
        <div class="absolute inset-0 bg-gradient-to-t from-htbw-green/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <span class="absolute bottom-4 left-4 text-white font-heading font-bold text-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300">Antiheld</span>
      </div>
      
      {# Stats/Quote box #}
      <div class="col-span-4 md:col-span-2 lg:col-span-5 row-span-2 bg-htbw-cream border-2 border-htbw-green/20 rounded-2xl flex items-center justify-center p-6" data-animate>
        <blockquote class="text-center">
          <p class="text-htbw-black italic text-sm md:text-base">&laquo;Super Atmosphäre und tolle Künstler:innen! Ich komme jedes Jahr wieder :)&raquo;</p>
          <cite class="text-htbw-green text-xs mt-2 block">- Mirja</cite>
        </blockquote>
      </div>
      
    </div>
  </div>
</section>

{# Aftermovies Section #}
<section id="aftermovies" class="section relative overflow-hidden">
          
  {# Watercolor decorations #}
  <div class="watercolor-blob -top-20 -left-20 w-64 h-64 animate-float-slow" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-2-pink-s.avif' | url }}" alt="" class="w-full h-full object-contain">
  </div>
  <div class="watercolor-blob -bottom-10 -right-10 w-48 h-48 animate-float-slow" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-4-grün-s.avif' | url }}" alt="" class="w-full h-full object-contain">
  </div>

  <div class="max-w-7xl mx-auto">
    <h2 class="section-title" data-animate>Aftermovies 🎥</h2>
    <p class="text-center text-lg md:text-xl text-htbw-black mb-12 max-w-2xl mx-auto" data-animate>
      Unser Aftermovie für 2025 ist da! Vielleicht entdeckst du ja jemanden den oder die du kennst 🎬
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {% for video in aftermovies.aftermovies %}
      <article class="sticker-card" data-animate>
        <div class="relative" style="padding-bottom: 56.25%;">
          {# YouTube Placeholder - will be replaced after play init #}
          <div 
            class="youtube-placeholder absolute inset-0"
            data-youtube-id="{{ video.youtubeVideoId }}"
            data-video-title="{{ video.title }}"
          >
            {% image video.youtubeThumbnail, video.alt, "(min-width: 768px) 50vw, 100vw", "absolute inset-0 w-full h-full object-cover rounded-lg" %}
            <div class="video-overlay absolute inset-0 bg-black/40 flex flex-col items-center justify-center rounded-lg">
              <div class="play-btn-wrapper flex flex-col items-center justify-center gap-3">
                <button 
                  type="button"
                  class="w-16 h-16 bg-htbw-pink rounded-full flex items-center justify-center hover:bg-htbw-pink-dark transition-colors mb-3"
                  data-video-trigger
                  data-video-inline
                  data-video-id="{{ video.youtubeVideoId }}"
                  aria-label="{{ video.title }} abspielen"
                >
                  <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </button>
                <p class="text-white text-sm bg-htbw-pink px-2">Klicken zum Abspielen</p>
              </div>
            </div>
          </div>
        </div>
        <h3 class="font-body font-bold text-2xl text-htbw-green mt-4">{{ video.title }}</h3>
      </article>
      {% endfor %}
    </div>

  </div>
</section>

{# Past Artists / Slider of Fame Section #}
<section id="pastArtists" class="section bg-htbw-pink/10">
  <div class="max-w-7xl mx-auto">
    <h2 class="section-title" data-animate>Unser Slider of Fame ✨</h2>
    <p class="text-center text-lg md:text-xl text-htbw-black mb-8 max-w-2xl mx-auto" data-animate>
      Alle Künstlerinnen und Künstler, die in den letzten Jahren bei uns auf der Bühne standen.
    </p>

    {# Year Tabs #}
    <div class="flex flex-wrap justify-center gap-2 mb-8" data-year-tabs role="tablist" aria-label="Jahre">
      {% set years = pastArtists | getYears %}
      {% for year in years %}
      <button 
        class="year-tab {% if loop.first %}active{% endif %}"
        data-year="{{ year }}"
        role="tab"
        aria-selected="{% if loop.first %}true{% else %}false{% endif %}"
      >
        {{ year }}
      </button>
      {% endfor %}
    </div>

    {# Year Panels #}
    {% for year in years %}
    <div 
      class="{% if not loop.first %}hidden{% endif %}" 
      data-year-panel="{{ year }}"
      role="tabpanel"
      aria-label="Künstler {{ year }}"
    >
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {% for artist in pastArtists[year] %}
        <article class="sticker-card text-center" data-animate>
          <div class="overflow-hidden mb-3 relative">
              {% image artist.image, artist.alt, "(min-width: 1280px) 20vw, (min-width: 768px) 25vw, 50vw", "w-full h-full object-cover" %}
            {% if artist.youtubeVideoId %}
            <button 
              type="button"
              class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 hover:opacity-100 transition-opacity"
              data-video-trigger
              data-video-id="{{ artist.youtubeVideoId }}"
              aria-label="Video von {{ artist.name }} aus {{ year }} ansehen"
            >
              <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
            {% endif %}
          </div>
          <h3 class="font-body text-htbw-green text-md">{{ artist.name }}</h3>
        </article>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

{# Festival Map Section #}
<section id="map" class="section relative overflow-hidden">
  {# Watercolor decorations #}
  <div class="watercolor-blob -top-20 -right-10 w-64 h-64 animate-float-slow" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-8-beige-s.avif' | url }}" alt="" class="w-full h-full object-contain">
  </div>
  <div class="watercolor-blob -bottom-10 -left-10 w-48 h-48 animate-float-slow" aria-hidden="true">
    <img src="{{ '/assets/images/watercolor/small/klecks-7-grün-s.avif'  | url }}" alt="" class="w-full h-full object-contain">
  </div>

  <div class="max-w-7xl mx-auto">
    <h2 class="section-title" data-animate>Festivalgelände 🗺️</h2>
