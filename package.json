{
  "name": "htbw-website",
  "version": "1.1.0",
  "private": true,
  "description": "Horn to be Wild Festival Website - Die letzte Ausgabe 2026",
  "scripts": {
    "dev": "concurrently \"npm:watch:css\" \"npm:watch:11ty\"",
    "start": "concurrently \"npm:watch:css\" \"npm:watch:11ty\"",
    "build": "npm run build:css && npx @11ty/eleventy",
    "build:css": "npx tailwindcss -i ./src/css/style.css -o ./_site/css/style.css --minify",
    "watch:css": "npx tailwindcss -i ./src/css/style.css -o ./_site/css/style.css --watch",
    "watch:11ty": "npx @11ty/eleventy --serve --watch --port=3000"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
